# Assembled firmware artifacts (rebuild with `make`)
/build/
*.o
*.elf
*.hex
# ...but the frozen "original" firmware baseline in /tools/ IS committed, so the
# player can A/B the current firmware against the unmodified original.
!/tools/SwinSID88.original.elf
# ...and the released firmware binaries in /dist/ ARE committed (ready to flash).
!/dist/
!/dist/*.elf
!/dist/*.hex

# Emulator harness build output (the built DLL + exes in /tools/ are committed)
/sim/build/

# Rendered WAVs - not committed (the /tunes/ .sid files ARE committed)
*.wav

# Rendered audio output from the player
/output/

# .NET build output (player/)
[Bb]in/
[Oo]bj/

# Visual Studio / Rider IDE state
.vs/
*.suo
*.user

# Emulator build log
sim/build.log

# simavr lives in third_party/simavr as a git submodule; its build output is
# ignored by simavr's own .gitignore. The reference player (libsidplayfp) is an
# MSYS2 package statically linked into the DLL, so nothing extra to ignore here.
